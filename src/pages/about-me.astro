---
import danielImg from "@/assets/daniel.jpg";
import PageLayout from "@/layouts/Base.astro";
import { Image } from "astro:assets";

const meta = {
	description: "I'm a Web Developer",
	title: "About Me",
};
---

<PageLayout meta={meta}>
	<div class="space-y-6">
		<h1 class="title">About Me</h1>
		<p>
			Hi, I’m Daniel, a Full-Stack Developer from the Basque Country based in Argentina.
		</p>
		<div class="flex justify-center overflow-hidden md:h-42 md:w-42 relative mx-auto h-36 w-36 rounded-full lg:h-48 lg:w-48">
			<Image
				alt="Image of Daniel Penedo Lázaro"
				fetchpriority="high"
				class="h-full w-full object-cover"
				loading="eager"
				src={danielImg}
			/>
		</div>
		<p>I currently work at <a class="cactus-link" href="https://polyfen.ai">Polyfen</a>, maintaining WooCommerce and Shopify production systems for <b>bLoyal</b>'s loyalty platform and building a new UI with <b>React</b> and <b>GraphQL</b>. I also develop <b>Python</b> data pipelines for sociological research and build websites for independent clients. I’m passionate about <b>Linux</b> and open source. On the <a class="cactus-link" href="/posts">blog section</a>, I share scripts, tools, and web development notes.</p>
		<p>Outside of coding, I have a degree in Psychology and Comparative Literature from the Universitat Autònoma de Barcelona and I’m a graduated music teacher from the Instituto del Profesorado de Arte in Mar del Plata. I love reading, music, and the occasional rabbit hole.</p>
		<p>Feel free to contact me by <a class="cactus-link" href="mailto:danielpenedolazaro@gmail.com">email</a>, check my <a class="cactus-link" href="https://github.com/dpenedo">GitHub</a>, <a class="cactus-link" href="https://www.linkedin.com/in/daniel-penedo-lazaro/?locale=en_US">LinkedIn</a>, or my <a class="cactus-link" href="https://x.com/d_Penedo_">Twitter</a>!</p>
	</div>
</PageLayout>
