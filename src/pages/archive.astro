---
import pomodoroCapt from "/public/captura-pomodoro.png";
import martzianosCapt from "/public/captura-martzianos.png";
import doggyCapt from "/public/captura-doggy.png";
import aprovechappCapt from "/public/captura-aprovechapp.png";
import tuveterinariaCapt from "/public/captura-tuveterinaria.png";
import chronoscriptCapt from "/public/captura-chronoscript.webp";
import todolistCapt from "/public/captura-todolist.webp";
import tiendaCeramica from "/public/captura-tienda-ceramica.png";
import Project from "@/components/Project.astro";
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description:
		"Archive of older and learning projects by Daniel Penedo Lázaro: full-stack apps, desktop tools and course work.",
	title: "Project Archive",
};
---

<PageLayout meta={meta}>
	<section>
		<h1 class="title mb-4 text-2xl"><span class="text-accent">#</span> Project Archive</h1>
		<p class="mb-4">
			Older and learning projects. For my current work, see the projects on the
			<a class="cactus-link" href="/">home page</a>.
		</p>

		<h2 class="title mb-4 text-xl"><span class="text-accent">##</span> Full Stack Projects</h2>

		<!--Tienda de cerámica-->
		<Project
			img={tiendaCeramica}
			title="Ceramic Artisan E-Commerce Platform - Template/Showcase"
			repoLink="https://github.com/dPenedo/ceramic-ecommerce"
		>
			<p>
				An e-commerce platform designed for ceramic artisans, allowing them to showcase and sell
				unique, handcrafted pieces. The project was developed using <b class="text-quote">Django</b>
				as the backend framework, <b class="text-quote">Vanilla JavaScript</b> for dynamic interactions
				on the frontend, and <b class="text-quote">Tailwind CSS</b> for a modern, responsive design.
			</p>
		</Project>
		<!--ChronoScript-->
		<Project
			img={chronoscriptCapt}
			title="ChronoScript"
			repoLink="https://github.com/dPenedo/chronoscript"
			webLink1="https://chronoscript-react.netlify.app/"
			webLink2="https://chronoscript-js.netlify.app/"
			webLinkTitle1="Vanilla JS WebSite Link"
			webLinkTitle2="React TS Website Link"
		>
			<p>
				ChronoScript is a web application developed in two versions: one using <b class="text-quote"
					>Vanilla JavaScript</b
				>, HTML, and CSS, and the other with <b class="text-quote">React</b> and <b
					class="text-quote">TypeScript</b
				> using <b class="text-quote">Vite</b>. Both versions include three sections: Stopwatch,
				Countdown, and World-times (by consuming an API). They also utilize <b class="text-quote"
					>Jest</b
				> for testing.
			</p>
		</Project>

		<Project
			img={tuveterinariaCapt}
			title="tuVeterinaria - Django Ecommerce"
			repoLink="https://github.com/dPenedo/tuveterinaria"
		>
			<p>
				An ecommerce site built with Django Framework, featuring an SQLite database and user
				authentication. It was my final project for the UTN diploma on Django Full Stack
				development.
			</p>
		</Project>

		<Project
			img={aprovechappCapt}
			title="AprovechÁpp! - Spring WebApp"
			repoLink="https://github.com/dPenedo/aprovechapp"
		>
			<p>
				A Web App built with the Spring Framework. It was my final project for the UTN diploma on <b
					class="text-quote">Spring Boot</b
				> development.
			</p>
		</Project>

		<Project
			img={doggyCapt}
			title="Doggy - Django WebApp"
			repoLink="https://github.com/No-Country/c6-15-ft-python-/"
		>
			<p>
				An online dog boarding service. It's dynamic and built with Django Framework and <b
					class="text-quote">PostgreSQL</b
				>.
			</p>
		</Project>
		<Project
			img={todolistCapt}
			title="TodoList - Django + React WebApp"
			repoLink="https://github.com/dPenedo/drf-react-todolist"
		>
			<p>
				A full-stack To-Do List application built with <b class="text-quote"
					>Django Rest Framework (DRF)</b
				> and <b class="text-quote">React</b>
			</p>
		</Project>
		<!--Python-->
		<h2 class="title my-6 mt-8 text-xl">
			<span class="text-accent">##</span> Python Desktop Projects
		</h2>

		<Project
			img={pomodoroCapt}
			title="Pomodoro Desktop App"
			repoLink="https://github.com/dPenedo/pomodoro"
		>
			<p>
				A Pomodoro timer made in Python using the <b class="text-quote">TkInter</b> library.
			</p>
		</Project>

		<Project
			img={martzianosCapt}
			title="Martzianos War"
			repoLink="https://github.com/dPenedo/martzianos"
		>
			<p>
				A Space Invaders style game made with the <b class="text-quote">Pygame</b> library.
			</p>
		</Project>
	</section>
</PageLayout>
