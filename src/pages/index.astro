---
import { Image } from "astro:assets";
import SocialList from "@/components/SocialList.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import PageLayout from "@/layouts/Base.astro";
import { getAllPosts, sortMDByDate } from "@/data/post";
import danielImage from "../assets/daniel.jpg";
import ProjectsSection from "@/components/ProjectsSection.astro";

const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS);
---

<PageLayout meta={{ title: "dPenedo" }}>
	<section class="flex flex-col">
		<div
			class="md:h-42 md:w-42 relative mx-auto h-36 w-36 overflow-hidden rounded-full lg:h-48 lg:w-48"
		>
			<Image
				src={danielImage}
				alt="picture of Daniel Penedo"
				class="h-full w-full rounded-full object-cover"
			/>
		</div>
<h1 class="title my-6">
  Hi, I'm <span class="text-3xl text-accent">Daniel Penedo Lázaro</span> 👋
</h1>
	</section>
<p class="mb-4">
I’m a Basque Full-Stack Developer based in Argentina. Currently at <a class="cactus-link" href="https://polyfen.ai">Polyfen</a>, maintaining WooCommerce and Shopify production systems for <b class="text-quote">bLoyal</b>’s loyalty platform and building a new UI with <b class="text-quote">React</b> and <b class="text-quote">GraphQL</b>.
</p>

<p class="mb-4">
I also develop <b class="text-quote">Python</b> data pipelines for sociological research at the Universidad de Mar del Plata, and build websites for independent clients. I enjoy automating things, writing clean code, and working close to the whole stack.
</p>
	<SocialList />

<!-- ========== Technologies  ========== -->
<section class="mt-16">
  <h2 class="title mb-4 text-2xl"><span class="text-accent">#</span> Technologies</h2>

  <p class="my-1 gap-2">
    <span class="text-accent">##</span><b> Programming Languages: </b>
    <b class="text-quote">Python</b>, <b class="text-quote">TypeScript</b>,
    <b class="text-quote">PHP</b>, <b class="text-quote">SQL</b>,
    and <b class="text-quote">Bash</b>.
  </p>

  <p class="my-1 gap-2">
    <span class="text-accent">##</span><b> Back End: </b>
    <b class="text-quote">GraphQL</b> and REST APIs.
  </p>

  <p class="my-1 gap-2">
    <span class="text-accent">##</span><b> Front End: </b>
    <b class="text-quote">React</b>, <b class="text-quote">Next.js</b>, <b class="text-quote">Astro</b>, <b class="text-quote">Tailwind</b>,
    <b class="text-quote">SASS</b>, and <b class="text-quote">Storybook</b>.
  </p>

  <p class="my-1 gap-2">
    <span class="text-accent">##</span><b> Data & Automation: </b>
    <b class="text-quote">Pandas</b>,
    <b class="text-quote">Plotly</b>, <b class="text-quote">Streamlit</b>,
    <b class="text-quote">BeautifulSoup</b>, and <b class="text-quote">Requests</b>.
  </p>

  <p class="my-1 gap-2">
    <span class="text-accent">##</span><b> DevOps: </b>
    <b class="text-quote">Linux</b>, <b class="text-quote">Git</b>,
    <b class="text-quote">Docker</b>, and CI/CD pipelines.
  </p>

  <p class="my-1 gap-2">
    <span class="text-accent">##</span><b> Design Tools: </b>
    Figma, Gimp, and Inkscape.
  </p>
</section>
<!-- ========== Technologies   ========== -->

					<ProjectsSection />

					<!-- ========== Posts  ========== -->
					<section aria-label="Blog post list" class="mt-16">
						<h2 class="title mb-4 text-2xl"><span class="text-accent"># </span> Blog Posts</h2>
						<ul class="space-y-4">
							{
								allPostsByDate.map((p) => (
									<li class="flex flex-col gap-x-2 sm:flex-row">
										<PostPreview post={p} />
									</li>
								))
							}
						</ul>
					</section>
					<!-- ========== Posts   ========== -->
				</p>
			</p>
		</p>
	</section>
</PageLayout>
