---
import basqueMediaCapt from "/public/captura-basquemedia.png";
import scrapingCapt from "/public/captura-scraping.png";
import albertCapt from "/public/captura-alber.png";
import sociometroCapt from "/public/captura-sociometro.png";
import escuelaDeColumnaCapt from "public/captura-escuela-col.webp";
import cityBike from "/public/captura-citybike.png";
import matafuegos from "/public/captura-matafuegos1.png";
import Project from "./Project.astro";
---

<section class="mt-16">
	<h2 class="title mb-4 text-2xl"><span class="text-accent">#</span> Projects</h2>

	<div>
		<h2 class="title mb-4 text-xl"><span class="text-accent">##</span> Data Projects</h2>
		<!-- <h2 class="title mb-4 text-xl"><a class="cactus-link" href="/data"><span class="text-accent">##</span> Data Projects</a></h2> -->

		<Project
			img={scrapingCapt}
			title="News Scraper - Argentine Media Data Pipeline"
			repoLink="https://github.com/dPenedo/news_scraper"
			webLink1="https://humanidades.mdp.edu.ar/secretarias-subsecretarias/secretaria-de-transferencia-vinculacion-internacional-e-innovacion/observatorios/ospo/"
			webLinkTitle1="OSPO Research Group"
		>
			<p>
				A <b class="text-quote">Python</b>-based web scraper that collects headlines, URLs, and metadata from
				<b class="text-quote">9 Argentine news outlets</b>: local Mar del Plata media and national sources
				(Clarín, La Nación, Página 12, Infobae). Developed for the <b class="text-quote">OSPO sociological research group</b>
				at the Universidad de Mar del Plata. Runs daily on a <b class="text-quote">VPS</b> and stores results in CSV files.
			</p>
			<p>
				Built with <b class="text-quote">BeautifulSoup</b> and <b class="text-quote">Requests</b>, object-oriented modular
				architecture, a <b class="text-quote">Cloudflare Worker proxy</b> to bypass IP blocks,
				<b class="text-quote">Docker</b> for deployment, and tests via <b class="text-quote">pytest</b>.
			</p>
		</Project>

		<Project
			img={basqueMediaCapt}
			title="Basque Media Scraper - Multi-Source News Data Pipeline"
			repoLink="https://github.com/dPenedo/basque_media"
		>
			<p>
				A <b class="text-quote">Python</b>-based web scraping system that collects headlines from
				<b class="text-quote">13 Basque and Spanish media outlets</b>, storing them in a
				<b class="text-quote">PostgreSQL</b> database with automatic duplicate prevention.
			</p>
			<p>
				The project features a <b class="text-quote">modular object-oriented architecture</b>,
				supports both
				<b class="text-quote">database</b> and <b class="text-quote">CSV</b> storage modes, and includes
				<b class="text-quote">database views</b> for real-time statistics. It runs daily on a
				<b class="text-quote">VPS via Docker</b> with cron automation for continuous data collection.
			</p>
		</Project>
		<Project
			img={sociometroCapt}
			title="Basque Sociometer - Official Survey Data Analysis App"
			repoLink="https://github.com/dPenedo/sociometro-vasco"
			webLink1="/data/es/sociometro-vasco"
			webLink2="/data/eus/sociometro-vasco"
			webLinkTitle1="Application Link (Spanish)"
			webLinkTitle2="Application Link (Basque)"
		>
			<p>
				A data analysis application built on official periodic studies of the Basque population
				developed with <b class="text-quote">Python</b>, <b class="text-quote">Pandas</b> for data processing,
				and <b class="text-quote">Plotly</b> & <b class="text-quote">Streamlit</b> for interactive visualizations
				and deployment. Features interactive filtering by age, sex, social class, education level, and
				knowledge of the Basque language (<i>Euskera</i>).
			</p>
		</Project>


		<h2 class="title mb-4 text-xl"><span class="text-accent">##</span> AI & Automation Projects</h2>

		<Project
			img={cityBike}
			title="CityBike Rental - AI Customer Service Bot"
			webLink1="https://t.me/CityBikeRentalBot"
		>
			<p>
				An <b class="text-quote">AI customer service system</b> showcasing
				<b class="text-quote">conversational AI</b> capabilities for enterprise support. Integrates <b
					class="text-quote">DeepSeek LLM</b
				> with <b class="text-quote">Telegram Bot API</b>
				for natural language understanding and response generation.
			</p>
			<p>
				Implements <b class="text-quote">professional support workflows</b> including pricing inquiries,
				location services, technical troubleshooting, and human escalation protocols. Features <b
					class="text-quote">Docker deployment</b
				> on a <b class="text-quote">VPS</b> and
				<b class="text-quote">custom prompt engineering</b> for consistent, on-brand responses.
			</p>
		</Project>

		<h2 class="title mb-4 text-xl">
			<span class="text-accent">##</span> Freelance / Client Work
		</h2>

		<Project
			img={matafuegos}
			title="Matafuegos Mar del Plata - [Live Site]"
			webLink1="https://matafuegosmardelplata.com.ar"
		>
			<p>
				Complete rebuild of an existing fire safety company website with focus on <b
					class="text-quote">SEO optimization</b
				>, <b class="text-quote">performance improvements</b> and <b class="text-quote"
					>modern UX/UI</b
				>.
			</p>
			<p>
				Developed using <b class="text-quote">Astro framework</b> with <b class="text-quote"
					>React components</b
				> and <b class="text-quote">Tailwind CSS</b>, achieving <b class="text-quote"
					>90+ PageSpeed score</b
				> through optimized assets and efficient code structure.
			</p>
		</Project>
		<!--Escuela de columna-->
		<Project
			img={escuelaDeColumnaCapt}
			title="Escuela de Columna - [Live Site]"
			webLink1="https://escueladecolumna.com.ar/"
		>
			<p>
				A website created for a multidisciplinary team of healthcare professionals, including
				physiotherapists and doctors. This project was developed using the <b class="text-quote"
					>Next.js</b
				> framework for
				<b class="text-quote">React</b> and <b class="text-quote">Tailwind CSS</b>.
			</p>
		</Project>

		<!-- Albert -->
		<Project
			img={albertCapt}
			title="Albert Martin - [Live Site]"
			webLink1="https://albertmediador.com"
		>
			<p>
				A psychologist and mediator's Website. I also made the design, It's static and built with <b
					class="text-quote">Bootstrap</b
				>.
			</p>
		</Project>

		<p class="mt-6">
			Older and learning projects live in the
			<a class="cactus-link" href="/archive/">project archive</a>.
		</p>
	</div>
</section>
